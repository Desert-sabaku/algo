{
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.ruff": "explicit",
        "source.organizeImports.ruff": "explicit"
    },
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "cSpell.words": [
        "Analysing",
        "docstrings",
        "Hoare",
        "Lomuto",
        "Mypy",
        "newpassword",
        "organise",
        "platformdirs",
        "postconditions",
        "pycache",
        "pylint",
        "pyproject",
        "pytest",
        "rslt",
        "venv"
    ]
}
